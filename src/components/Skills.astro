---
const { skills } = Astro.props;
---
<section class="skills-container">
  {
    skills && Object.entries(skills).map(([key, value]) => (
      <div class="group">
        <h3>{key}</h3>
        <ul>
          {
            value.map((skill) => (
              <li>{skill}</li>
            ))
          }
        </ul>
      </div>
    ))
  }
</section>

<style>
.skills-container {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

@media only screen and (min-width: 600px) {
  .skills-container {
    grid-template-columns: repeat(3, 1fr);
  }
}

.group {
  background: white;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 18px 20px;
  box-shadow: var(--shadow-sm);
}

.group h3 {
  margin: 0 0 12px;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: capitalize;
  letter-spacing: 0.02em;
  color: var(--muted);
}

ul {
  display: flex;
  flex-wrap: wrap;
  list-style: none;
  padding: 0;
  margin: 0;
  gap: 6px;
}

li {
  color: var(--text);
  background-color: var(--accent-soft);
  border: 1px solid rgba(242, 148, 75, 0.25);
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 0.82rem;
  font-weight: 500;
  transition: transform 0.15s ease, background-color 0.15s ease;
}

li:hover {
  background-color: var(--accent);
  color: white;
  transform: translateY(-1px);
}
</style>
