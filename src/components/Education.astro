---
const { education } = Astro.props;
---
<section class="card">
  <div class="header">
    <div>
      <h3>{education.degree}</h3>
      <p class="school">{education.school}</p>
    </div>
    <span class="date">{education.startDate} – {education.endDate}</span>
  </div>
  <p class="location">{education.location}</p>
  <p class="gpa"><span>Cumulative average:</span> {education.gpa}</p>
</section>

<style>
.card {
  background: white;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 22px 24px;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  border-color: rgba(242, 148, 75, 0.4);
}

.header {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  justify-content: space-between;
  gap: 4px 16px;
}

h3 {
  margin: 0;
  font-size: 1.15rem;
  font-weight: 600;
}

.school {
  margin: 2px 0 0;
  font-weight: 500;
  color: var(--link);
  font-size: 0.95rem;
}

.date {
  font-size: 0.85rem;
  color: var(--muted);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.location {
  margin: 6px 0 12px;
  font-size: 0.85rem;
  color: var(--muted);
  font-style: italic;
}

.gpa {
  margin: 0;
  font-size: 0.95rem;
}

.gpa span {
  color: var(--muted);
}
</style>
