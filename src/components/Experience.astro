---
const { experience } = Astro.props;
---
<section class="card">
  <div class="header">
    <div>
      <h3>{experience.title}</h3>
      <p class="company">{experience.company}</p>
    </div>
    <span class="date">{experience.startDate} – {experience.endDate}</span>
  </div>
  <p class="location">{experience.location}</p>
  <ul>
    {
      experience.highlights.map((highlight) => (
        <li>{highlight}</li>
      ))
    }
  </ul>
</section>

<style>
.card {
  background: white;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 22px 24px;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  border-color: rgba(242, 148, 75, 0.4);
}

.header {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  justify-content: space-between;
  gap: 4px 16px;
}

h3 {
  margin: 0;
  font-size: 1.15rem;
  font-weight: 600;
}

.company {
  margin: 2px 0 0;
  font-weight: 500;
  color: var(--link);
  font-size: 0.95rem;
}

.date {
  font-size: 0.85rem;
  color: var(--muted);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.location {
  margin: 6px 0 12px;
  font-size: 0.85rem;
  color: var(--muted);
  font-style: italic;
}

ul {
  margin: 0;
  padding-left: 18px;
}

li {
  margin-bottom: 6px;
  line-height: 1.55;
}

li:last-child {
  margin-bottom: 0;
}
</style>
