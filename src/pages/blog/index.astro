---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Layout>
  <div class="main-container">
    <header class="page-header">
      <h1>Blog</h1>
      <p>Notes on things I'm working on or thinking about.</p>
    </header>

    {posts.length === 0 ? (
      <p class="empty">No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="post-card">
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {dateFmt.format(post.data.pubDate)}
                </time>
              </div>
              <h2>{post.data.title}</h2>
              {post.data.description && <p class="desc">{post.data.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>

<style>
.main-container {
  max-width: 820px;
  margin: 0 auto;
  padding: 56px 24px 80px;
  animation: fade-in 0.6s ease both;
}

.page-header {
  text-align: center;
  margin-bottom: 48px;
}

.page-header h1 {
  font-size: clamp(2rem, 4vw, 2.6rem);
  margin: 0 0 12px;
}

.page-header p {
  color: var(--muted);
  margin: 0;
  font-size: 1.05rem;
}

.empty {
  text-align: center;
  color: var(--muted);
}

.post-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.post-card {
  display: block;
  background: white;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 22px 24px;
  box-shadow: var(--shadow-sm);
  color: var(--text);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.post-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  border-color: rgba(242, 148, 75, 0.4);
  color: var(--text);
}

.post-meta {
  font-size: 0.85rem;
  color: var(--muted);
  font-variant-numeric: tabular-nums;
  margin-bottom: 6px;
}

.post-card h2 {
  margin: 0;
  font-size: 1.2rem;
  font-weight: 600;
}

.desc {
  margin: 8px 0 0;
  color: var(--muted);
  font-size: 0.95rem;
  line-height: 1.55;
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
