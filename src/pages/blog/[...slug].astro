---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout>
  <article class="main-container">
    <a href="/blog" class="back">← Back to blog</a>
    <header class="post-header">
      <time datetime={post.data.pubDate.toISOString()}>
        {dateFmt.format(post.data.pubDate)}
      </time>
      <h1>{post.data.title}</h1>
      {post.data.description && <p class="desc">{post.data.description}</p>}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
.main-container {
  max-width: 720px;
  margin: 0 auto;
  padding: 40px 24px 80px;
  animation: fade-in 0.6s ease both;
}

.back {
  display: inline-block;
  margin-bottom: 32px;
  color: var(--muted);
  font-size: 0.9rem;
}

.back:hover {
  color: var(--accent);
}

.post-header {
  margin-bottom: 40px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--border);
}

.post-header time {
  font-size: 0.9rem;
  color: var(--muted);
}

.post-header h1 {
  font-size: clamp(1.8rem, 4vw, 2.4rem);
  margin: 12px 0 0;
}

.post-header .desc {
  margin: 12px 0 0;
  color: var(--muted);
  font-size: 1.05rem;
  line-height: 1.55;
}

.prose {
  font-size: 1.02rem;
  line-height: 1.75;
  color: var(--text);
}

.prose :global(h2) {
  margin: 2em 0 0.6em;
  font-size: 1.4rem;
}

.prose :global(h3) {
  margin: 1.6em 0 0.5em;
  font-size: 1.15rem;
}

.prose :global(p) {
  margin: 0 0 1.1em;
}

.prose :global(a) {
  color: var(--link);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
}

.prose :global(a:hover) {
  color: var(--accent);
}

.prose :global(ul),
.prose :global(ol) {
  padding-left: 24px;
  margin: 0 0 1.1em;
}

.prose :global(li) {
  margin-bottom: 6px;
}

.prose :global(code) {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  background: var(--bg-soft);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1px 6px;
  font-size: 0.92em;
}

.prose :global(pre) {
  background: #1c1c1c;
  color: #f5f5f5;
  padding: 16px 18px;
  border-radius: 10px;
  overflow-x: auto;
  font-size: 0.92em;
  line-height: 1.55;
  margin: 0 0 1.4em;
}

.prose :global(pre code) {
  background: transparent;
  border: none;
  padding: 0;
  color: inherit;
  font-size: inherit;
}

.prose :global(blockquote) {
  margin: 0 0 1.1em;
  padding: 4px 18px;
  border-left: 3px solid var(--accent);
  background: var(--bg-soft);
  color: var(--muted);
  font-style: italic;
  border-radius: 0 6px 6px 0;
}

.prose :global(img) {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 1.2em 0;
}

.prose :global(hr) {
  border: none;
  border-top: 1px solid var(--border);
  margin: 2em 0;
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
